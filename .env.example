# Имя пакета Flask (позволяет запускать `flask run` без флагов)
FLASK_APP=yacut

# Окружение Flask (development, production, testing)
FLASK_ENV=development

# Секретный ключ для сессий и CSRF
SECRET_KEY=your-super-secret-key-here-change-in-prod

# URI базы данных. Для тестов автоматически переопределяется на sqlite:///:memory:
DATABASE_URI=sqlite:///db.sqlite3

# Токен для доступа к API Яндекс Диска
DISK_TOKEN=your-yandex-disk-api-token

# Базовый URL API Яндекс Диска
YADISK_API_BASE_URL=https://cloud-api.yandex.net/v1/disk/resources